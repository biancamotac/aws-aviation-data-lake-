
from awsglue.context import GlueContext
from pyspark.context import SparkContext
from pyspark.sql.functions import *

sc = SparkContext.getOrCreate()
glueContext = GlueContext(sc)
spark = glueContext.spark_session

df = spark.read.csv(
    "s3://bianca-aviation-data-lake-2026-578101931561-sa-east-1-an/raw/aviation_accidents/",
    header=True,
    inferSchema=True
)

df = df.dropDuplicates()

df = df.withColumn(
    "ocorrencia_dia",
    to_date(col("ocorrencia_dia"))
)

df = df.withColumn(
    "ano",
    year(col("ocorrencia_dia"))
)

df = df.withColumn(
    "mes",
    month(col("ocorrencia_dia"))
)

df.write.mode("overwrite") \
    .partitionBy("ano", "mes") \
    .parquet(
        "s3://bianca-aviation-data-lake-2026-578101931561-sa-east-1-an/processed/aviation/"
)
